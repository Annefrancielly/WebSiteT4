NODE_ENV=development
PORT=3333

# Em produção, use o domínio real do front.
# Aceita múltiplos domínios separados por vírgula.
CORS_ORIGIN=http://localhost:3000

# Swagger
SWAGGER_ENABLED=true
SWAGGER_PATH=docs

# Rate limit global
THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT=120

# development: seed ou mysql
# production: mysql
SURF_TRIPS_DRIVER=seed

# --- MySQL ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_CONN_LIMIT=10
DB_CONNECT_TIMEOUT_MS=5000